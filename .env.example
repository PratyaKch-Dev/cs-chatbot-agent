# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Vector DB ─────────────────────────────────────────────────────────────────
VECTOR_BACKEND=qdrant                  # qdrant | pinecone
QDRANT_HOST=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
PINECONE_API_KEY=your-pinecone-api-key  # only if VECTOR_BACKEND=pinecone

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LINE ──────────────────────────────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# ── Observability ─────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=cs-chatbot-agent
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic                 # anthropic | openai | google
LLM_MODEL=claude-3-haiku-20240307      # override default model for the chosen provider
# OPENAI_API_KEY=sk-...               # required if LLM_PROVIDER=openai
# GOOGLE_API_KEY=...                  # required if LLM_PROVIDER=google

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_EMBEDDING_CACHE=true
ENABLE_PARALLEL_PROCESSING=false

# Force the mock employee/attendance clients even when a Bearer token is present.
# Default behaviour (USE_MOCK_APIS unset or false): token presence is the switch —
#   Bearer token in the request  → real API
#   no token (Gradio Employee ID path, scenario scripts, no LINE auth)  → mock
# Set USE_MOCK_APIS=true to force mock for debugging without hitting the backend.
USE_MOCK_APIS=false

# ── Internal HR API (real clients) ────────────────────────────────────────────
# Per-environment base URL for the chatbot profile/attendance endpoints.
#   dev       → https://apiv2-dev.salary-hero.com
#   staging   → https://apiv2-staging.salary-hero.com   (example)
#   prod      → https://api.salary-hero.com             (example)
INTERNAL_API_BASE_URL=https://apiv2-dev.salary-hero.com

# Disable TLS verification for local dev behind self-signed / corporate-MITM certs.
# MUST be true in staging/prod.
API_VERIFY_SSL=true

# App-identity headers the BE auth/middleware expects. Defaults match the iOS
# dev build; override per-deployment if needed.
API_DEVICE_ID=6997E41A-86E8-5003-977C-CE346154EF79
API_APP_VERSION=5.4.4
API_OS_PLATFORM=ios
API_USER_AGENT=Dev/10102724 CFNetwork/3860.400.51 Darwin/25.3.0
